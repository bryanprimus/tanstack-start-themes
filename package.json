{
  "name": "tanstack-start-themes",
  "type": "module",
  "version": "0.0.0",
  "description": "A theme provider for TanStack applications",
  "author": "Bryan Primus",
  "license": "MIT",
  "homepage": "https://github.com/bryanprimus/tanstack-start-themes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanprimus/tanstack-start-themes.git"
  },
  "bugs": {
    "url": "https://github.com/bryanprimus/tanstack-start-themes/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0"
  }
}
